{
  "name": "snap-engine",
  "version": "0.1.0",
  "description": "high-performance scroll snapping engine for building TikTok-like feeds.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "keywords": [
    "feed",
    "scroll snapping",
    "virtualization",
    "tiktok",
    "reels"
  ],
  "author": "eren | eren.jp | mrberenben",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "oxlint packages",
    "lint:fix": "oxlint packages --fix",
    "fmt": "oxfmt packages",
    "fmt:check": "oxfmt packages --check"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "path": "^0.12.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
